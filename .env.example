# ── Click (SHOP API) ──────────────────────────────────────────────────────
# Cabinet: https://my.click.uz/  →  My services / Account / API settings
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
# "Secret key" from Click support (NOT your login password). Used to verify the
# MD5 signature on every prepare/complete callback. Keep it server-side only.
CLICK_SECRET_KEY=

# ── Payme (Paycom) ────────────────────────────────────────────────────────
# Cabinet: https://merchant.paycom.uz/
# Kassa ID (a.k.a. Merchant ID), shown at the top of your Касса.
PAYME_MERCHANT_ID=
# Production secret key (Cabinet → Настройки → API endpoint).
PAYME_SECRET_KEY=
# Test/sandbox key — keep it set so https://test.paycom.uz/ tests keep passing.
PAYME_TEST_KEY=
# The single cart-field name you defined in the cabinet (Поля корзины).
# Must match the cabinet EXACTLY and never change after go-live.
PAYME_ACCOUNT_FIELD=order_id

# ── App ───────────────────────────────────────────────────────────────────
# Public base URL used to build return_url for the hosted payment pages.
NEXT_PUBLIC_SITE_URL=https://yourapp.com
# Set to "true" to send Payme users to the sandbox checkout instead of prod.
PAYME_SANDBOX=false
